{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/cunningfolkmedia/me-md/schema/me.schema.json",
  "title": "me.md front matter",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "me_md_version",
    "profile",
    "visibility",
    "updated"
  ],
  "properties": {
    "me_md_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "profile": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "display_name",
        "preferred_name",
        "role"
      ],
      "properties": {
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "preferred_name": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "organization": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "public_bio": {
          "type": "string"
        }
      }
    },
    "organization": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "handle": {
          "type": "string"
        }
      }
    },
    "visibility": {
      "type": "string",
      "enum": [
        "public",
        "team",
        "private",
        "confidential",
        "redacted"
      ]
    },
    "updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "context": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "purpose": {
          "type": "string"
        },
        "audience": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "freshness": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "reviewed": {
          "type": "string"
        },
        "review_cycle": {
          "type": "string"
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}